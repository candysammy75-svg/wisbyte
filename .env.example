# ============================================================
#  Dragon Shop Bot — متغيرات البيئة المطلوبة
#  انسخ الملف ده وسميه .env وحط القيم الحقيقية
# ============================================================

# توكين البوت من Discord Developer Portal
# Bot → Token
DISCORD_TOKEN=your_bot_token_here

# ID السيرفر (كليك يمين على السيرفر → Copy Server ID)
GUILD_ID=your_guild_id_here

# ID حسابك على Discord (كليك يمين على اسمك → Copy User ID)
OWNER_ID=your_owner_id_here

# رابط قاعدة البيانات PostgreSQL
# مثال Supabase: postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres
# مثال Railway:  postgresql://postgres:PASSWORD@xxx.railway.app:5432/railway
DATABASE_URL=postgresql://user:password@host:5432/dbname

# مستوى اللوج (اختياري — info أو debug أو warn)
LOG_LEVEL=info

# بورت السيرفر (اختياري — افتراضي 8080)
PORT=8080
